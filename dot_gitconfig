	email = me@m1sk9.dev
	signingKey = 9700B737B52570D7B78394E52DF1A76B8DC2D6E3
[push]
	default = current
[pull]
	ff = only
	rebase = false
    default = current
[init]
	defaultbranch = main
[core]
	autocrlf = input
	ignorecase = false
	editor = vim
	quotepath = false
[color]
	ui = true
	diff = auto
	status = auto
	branch = auto
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[rerere]
    enabled = true
[gpg]
	program = gpg
[rebase]
	updateRefs = true
[fetch]
	prune = true
[status]
	showUntrackedFiles = all
[merge]
	conflictStyle = diff3
[alias]
	a = add
	s = status
	l = log --oneline --graph --decorate
	ls = log --show-signature
	sw = switch
	st = status -sb
	co = checkout
	br = branch
	ft = fetch
	cm = commit
